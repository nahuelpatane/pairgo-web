{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "brand": {
    "name": "Pairgo",
    "tagline": "Swap your job. Keep moving.",
    "description": "Job-swap platform for backpackers and workers across Australia."
  },
  "color": {
    "ink":          { "value": "#1A1A18", "comment": "primary text, dark backgrounds" },
    "inkSoft":      { "value": "#4A4A45", "comment": "secondary text" },
    "inkMuted":     { "value": "#8A8A82", "comment": "placeholders, tertiary text" },
    "sand":         { "value": "#FAFAF7", "comment": "page background (light mode)" },
    "sandDark":     { "value": "#F0EFE9", "comment": "dividers, subtle surfaces" },

    "coral":        { "value": "#E8654A", "comment": "primary brand, CTAs, highlights" },
    "coralDeep":    { "value": "#D4503A", "comment": "hover / active state of coral" },
    "coralGlow":    { "value": "#FFE8E2", "comment": "tinted badge / bg for coral" },

    "ocean":        { "value": "#2563EB", "comment": "info, secondary links" },
    "oceanSoft":    { "value": "#EFF6FF", "comment": "info backgrounds" },

    "forest":       { "value": "#1B7A5A", "comment": "success, active status" },
    "forestSoft":   { "value": "#ECFDF5", "comment": "success backgrounds" },

    "gold":         { "value": "#E5A100", "comment": "ratings, progress, accent bar" },
    "goldSoft":     { "value": "#FFF8E1", "comment": "rating backgrounds" }
  },
  "status": {
    "pending":   { "text": "#92400E", "bg": "#FEF3C7", "border": "#FDE68A" },
    "active":    { "text": "#065F46", "bg": "#D1FAE5", "border": "#A7F3D0" },
    "completed": { "text": "#1E40AF", "bg": "#DBEAFE", "border": "#93C5FD" },
    "declined":  { "text": "#6B7280", "bg": "#F3F4F6", "border": "#D1D5DB" }
  },
  "avatar": {
    "palette": ["#E8654A","#60A5FA","#A78BFA","#34D399","#F472B6","#FBBF24","#6EE7B7","#C084FC"],
    "algorithm": "lastCharCode % 8"
  },
  "typography": {
    "fontDisplay": "'Fraunces', serif",
    "fontBody":    "'DM Sans', sans-serif",
    "weights": {
      "regular":   400,
      "medium":    500,
      "semibold":  600,
      "bold":      700,
      "extrabold": 800
    },
    "scale": {
      "xs":   "11px",
      "sm":   "13px",
      "base": "15px",
      "md":   "17px",
      "lg":   "22px",
      "xl":   "26px",
      "2xl":  "36px",
      "3xl":  "clamp(32px, 4.5vw, 52px)",
      "hero": "clamp(42px, 5.8vw, 72px)",
      "cta":  "clamp(36px, 5vw, 56px)"
    }
  },
  "gradient": {
    "ctaButton":  "linear-gradient(135deg, #E8654A, #D4503A)",
    "accentBar":  "linear-gradient(90deg, #E8654A, #E5A100)",
    "accentAlt":  "linear-gradient(90deg, #E8654A, #A855F7)",
    "heroOverlay":"linear-gradient(to right, rgba(10,10,8,0.88) 0%, rgba(10,10,8,0.7) 45%, rgba(10,10,8,0.3) 100%)"
  },
  "shadow": {
    "subtle":  "0 2px 12px rgba(0,0,0,0.05)",
    "card":    "0 8px 40px rgba(0,0,0,0.10)",
    "modal":   "0 24px 56px rgba(0,0,0,0.55)",
    "coralGlow":"0 0 20px rgba(232,101,74,0.30)"
  },
  "radius": {
    "sm":   "9px",
    "md":   "14px",
    "lg":   "20px",
    "xl":   "24px",
    "pill": "100px",
    "full": "50%"
  },
  "motion": {
    "fast":   "0.15s",
    "normal": "0.25s",
    "slow":   "0.65s",
    "easing": "cubic-bezier(0.16, 1, 0.3, 1)"
  },
  "copy": {
    "taglines": [
      "Swap your job. Keep moving.",
      "Find someone in another city doing your same role. Swap positions. Travel with a guaranteed job from day one.",
      "From coffee shops to cattle farms."
    ],
    "stats": {
      "workers":   "2,400+",
      "swapsDone": "340+",
      "cities":    "6",
      "avgRating": "4.9★"
    },
    "cities": ["Sydney","Melbourne","Cairns","Byron Bay","Gold Coast","Perth"],
    "languages": ["English","Español","Français","Italiano","Português","日本語"]
  }
}
